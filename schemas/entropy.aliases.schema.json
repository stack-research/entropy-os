{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://entropy-os.dev/schemas/entropy.aliases.schema.json",
  "title": "entropy.aliases.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "aliases"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "aliases": {
      "type": "object",
      "default": {},
      "propertyNames": {
        "type": "string",
        "maxLength": 256,
        "pattern": "^(api|fn|state):(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._:/#-]+$"
      },
      "additionalProperties": {
        "type": "string",
        "maxLength": 256,
        "pattern": "^(api|fn|state):(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._:/#-]+$"
      }
    }
  }
}
